{
  "compilerOptions": {
    "incremental": true,
    "target": "ESNext",
    "module": "NodeNext",
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "isolatedModules": true
  },
  "include": ["src/**/*.ts", "src/**/*.json", "pladddform.root.ts"],
  "exclude": ["node_modules", "src/sdk"]
}
