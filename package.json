{
  "name": "unterrichtsplaner",
  "private": true,
  "version": "0.0.0",
  "description": "Ein Tool zur Planung von Unterrichtseinheiten und Erstellung von Lehrmaterial",
  "main": "app.js",
  "workspaces": [
    "packages/core",
    "packages/userInterface/cli",
    "packages/userInterface/electron",
    "packages/userInterface/next-js"
  ],
  "scripts": {
    "test": "npm run test --workspaces",
    "prepare": "husky",
    "build": "npm run build --workspaces"
  },
  "author": "Philipp Just",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "electron": "^40.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
